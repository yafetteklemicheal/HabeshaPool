                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_3"
                    app:layout_constraintRight_toLeftOf="@id/text_shooter_label_3"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/text_shooter_label_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="C"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_3"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_3"
                    app:layout_constraintRight_toRightOf="parent" />

                <TextView
                    android:id="@+id/text_player_score_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
