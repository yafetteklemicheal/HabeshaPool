                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_4"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_4"
                    app:layout_constraintRight_toLeftOf="@id/text_shooter_label_4"
