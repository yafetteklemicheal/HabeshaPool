<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/game_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".GameActivity">

    <!-- Header: Balls Still in Play -->
    <TextView
        android:id="@+id/text_balls_in_play_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="6dp"
        android:text="@string/header_balls_in_play"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_balls_sum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="120"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/text_balls_in_play_header"
        app:layout_constraintBottom_toBottomOf="@id/text_balls_in_play_header"
        app:layout_constraintLeft_toRightOf="@id/text_balls_in_play_header"/>

    <!-- GridLayout for current balls (populated dynamically using images) -->
    <GridLayout
        android:id="@+id/current_balls_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="7"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/text_balls_in_play_header"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="6dp" />

    <!-- ScrollView Container for Player Sections -->
    <ScrollView
        android:id="@+id/scroll_player_sections"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/current_balls_layout"
        app:layout_constraintBottom_toTopOf="@id/button_new_game"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:padding="10dp">

        <LinearLayout
            android:id="@+id/linear_player_sections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Player Section 1 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/player_section_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:background="#EFEFEF"
                android:padding="5dp">

                <!-- Player 1 Name -->
                <EditText
                    android:id="@+id/edit_player_name_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_player_name"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:maxLength="15"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@id/text_status_1"
                    android:layout_marginEnd="8dp" />

                <!-- Lead / Out-of-contention indicator 1 -->
                <TextView
                    android:id="@+id/text_status_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="#000000"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_1"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_1"
                    app:layout_constraintLeft_toRightOf="@id/edit_player_name_1"
                    app:layout_constraintRight_toLeftOf="@id/text_rank_emoji_1"
                    android:layout_marginEnd="4dp" />

                <!-- Rank Emoji 1 -->
                <TextView
                    android:id="@+id/text_rank_emoji_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_1"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_1"
                    app:layout_constraintRight_toLeftOf="@id/text_shooter_label_1"
                    android:layout_marginEnd="4dp" />

                <!-- Shooter Label A (right aligned) -->
                <TextView
                    android:id="@+id/text_shooter_label_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_1"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_1"
                    app:layout_constraintRight_toRightOf="parent" />

                <TextView
                    android:id="@+id/text_player_score_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/score_label_plain"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/edit_player_name_1"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent" />

                <Button
                    android:id="@+id/btn_score_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_score"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@id/btn_foul_1"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_1" />

                <Button
                    android:id="@+id/btn_foul_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_foul"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_score_1"
                    app:layout_constraintRight_toLeftOf="@id/btn_scratch_1"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_1" />

                <Button
                    android:id="@+id/btn_scratch_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_scratch"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_foul_1"
                    app:layout_constraintRight_toRightOf="@id/btn_undo_1"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_1" />

                <Button
                    android:id="@+id/btn_undo_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_undo"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_scratch_1"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_1" />

                <TextView
                    android:id="@+id/text_player_history_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/history_label"
                    app:layout_constraintTop_toBottomOf="@id/btn_score_1"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_marginTop="8dp" />

                <!-- Scored history images wrapped in a horizontal scroll -->
                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    app:layout_constraintTop_toBottomOf="@id/btn_scratch_1"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:id="@+id/linear_scored_history_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Player Section 2 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/player_section_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="#EFEFEF"
                android:padding="6dp">

                <EditText
                    android:id="@+id/edit_player_name_2"
