                    android:layout_height="wrap_content"
                    android:text="B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_2"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_2"
                    app:layout_constraintRight_toRightOf="parent" />

                <TextView
