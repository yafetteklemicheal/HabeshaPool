                <Button
                    android:id="@+id/btn_scratch_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_scratch"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_foul_3"
                    app:layout_constraintRight_toRightOf="@id/btn_undo_3"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_3" />

                <Button
                    android:id="@+id/btn_undo_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_undo"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_scratch_3"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_3" />

                <TextView
                    android:id="@+id/text_player_history_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/history_label"
                    app:layout_constraintTop_toBottomOf="@id/btn_score_3"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_marginTop="8dp" />

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    app:layout_constraintTop_toBottomOf="@id/btn_scratch_3"
                    app:layout_constraintLeft_toLeftOf="parent"
