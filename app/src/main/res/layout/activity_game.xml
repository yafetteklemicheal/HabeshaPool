                    android:textColor="#000000"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_4"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_4"
                    app:layout_constraintLeft_toRightOf="@id/edit_player_name_4"
                    app:layout_constraintRight_toLeftOf="@id/text_rank_emoji_4"
