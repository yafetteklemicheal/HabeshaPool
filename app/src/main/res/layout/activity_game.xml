                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="#000000"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_2"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_2"
                    app:layout_constraintLeft_toRightOf="@id/edit_player_name_2"
                    app:layout_constraintRight_toLeftOf="@id/text_rank_emoji_2"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/text_rank_emoji_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="@id/edit_player_name_2"
                    app:layout_constraintBottom_toBottomOf="@id/edit_player_name_2"
