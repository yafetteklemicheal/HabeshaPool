                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/edit_player_name_2" />

                <Button
                    android:id="@+id/btn_score_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_score"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@id/btn_foul_2"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_2" />

                <Button
                    android:id="@+id/btn_foul_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_foul"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_score_2"
                    app:layout_constraintRight_toLeftOf="@id/btn_scratch_2"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_2" />

                <Button
                    android:id="@+id/btn_scratch_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_scratch"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_foul_2"
                    app:layout_constraintRight_toRightOf="@id/btn_undo_2"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_2" />

                <Button
                    android:id="@+id/btn_undo_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_undo"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_scratch_2"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_2" />

                <TextView
                    android:id="@+id/text_player_history_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/history_label"
                    app:layout_constraintTop_toBottomOf="@id/btn_score_2"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_marginTop="8dp" />

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    app:layout_constraintTop_toBottomOf="@id/btn_scratch_2"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:id="@+id/linear_scored_history_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Aggregate score display for 2-player games -->
            <TextView
                android:id="@+id/text_aggregate_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/aggregate_tied"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:gravity="center"
                android:background="#DDDDDD"
                android:visibility="gone" />

            <!-- Player Section 3 -->
            <androidx.constraintlayout.widget.ConstraintLayout
