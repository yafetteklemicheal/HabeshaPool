                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@id/btn_foul_4"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_4" />

                <Button
                    android:id="@+id/btn_foul_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_foul"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_score_4"
                    app:layout_constraintRight_toLeftOf="@id/btn_scratch_4"
                    app:layout_constraintTop_toBottomOf="@id/text_player_score_4" />

                <Button
                    android:id="@+id/btn_scratch_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_scratch"
                    app:flow_horizontalAlign="center"
                    app:layout_constraintLeft_toRightOf="@id/btn_foul_4"
